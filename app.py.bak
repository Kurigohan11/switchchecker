#!/usr/bin/env python3
"""
SwitchPro v5 — диагностика коммутаторов

Исправления v5:
- MES2424B AC: определяется по серийнику ESF3xxxxx (Hardware Version 3v1)
- Команды исправлены по switch_commands.txt
- cable_result убран — тест сам выводит результат немедленно
- Порты: логика определения fa/gi/fa1/0/*/gi0/* передаётся с клиента (port_type)
- show_port убран
- Telnet порт 23 исправлен
"""

from flask import Flask, request, jsonify, render_template
import paramiko
import socket
import time
import logging
import traceback
import re

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_FILE = "switchpro.log"
_fh = logging.FileHandler(LOG_FILE, encoding="utf-8")
_sh = logging.StreamHandler()
_fmt = logging.Formatter("%(asctime)s [%(levelname)-7s] %(message)s", "%Y-%m-%d %H:%M:%S")
_fh.setFormatter(_fmt); _sh.setFormatter(_fmt)

log = logging.getLogger("switchpro")
log.setLevel(logging.DEBUG)
log.addHandler(_fh); log.addHandler(_sh)

pk = logging.getLogger("paramiko")
pk.setLevel(logging.DEBUG); pk.addHandler(_fh); pk.propagate = False

app = Flask(__name__)
log.info("=" * 60)
log.info("SwitchPro v5 запущен")

