# ─── Helpers ──────────────────────────────────────────────────────────────────

def load_password(path="passwords.txt"):
    try:
        with open(path, "r", encoding="utf-8") as f:
            return f.read().strip()
    except FileNotFoundError:
        log.error(f"Файл паролей не найден: {path}")
        return None


def check_tcp(host, port, timeout=6):
    try:
        s = socket.create_connection((host, port), timeout=timeout)
        s.close(); return True, None
    except socket.timeout:
        return False, f"Таймаут TCP {host}:{port} — хост не отвечает"
    except ConnectionRefusedError:
        return False, f"Порт {port} закрыт на {host}"
    except socket.gaierror as e:
        return False, f"DNS ошибка {host}: {e}"
    except OSError as e:
        return False, f"Сетевая ошибка: {e}"


def get_local_ip():
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80)); ip = s.getsockname()[0]; s.close(); return ip
    except Exception:
        return ""


def strip_ansi(text):
    return re.sub(r'\x1b\[[0-9;]*[mGKHFJA-Za-z]|\x1b\[?\d*[A-Za-z]|\r', '', text)


def _make_socket(host, port, source_ip, timeout):
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    if source_ip:
        try:
            s.bind((source_ip, 0))
        except OSError as e:
            log.warning(f"source_ip bind {source_ip}: {e}")
    s.settimeout(timeout)
    s.connect((host, port))
    return s


def match_model(text, prompt="", serial="", hw_version=""):
    """
    Определение модели. Порядок:
    1. Специфичная проверка MES2424B AC по серийнику ESF
    2. Промпт-паттерны (точное название в имени устройства)
    3. Detect-паттерны в тексте
    """
    upper_text  = text.upper()
    upper_all   = (prompt + "\n" + text + "\n" + serial).upper()

    # MES2424B AC: серийник начинается с ESF
    if serial.upper().startswith("ESF"):
        log.info(f"Модель по серийнику ESF: mes2424b_ac")
        return "mes2424b_ac"

    # Промпт-паттерны (только mes2424b/mes1124mb etc — не sf300 до detect)
    for mk, p in SWITCH_PROFILES.items():
        if mk == "cisco_sf300":  # sf300 проверяем только по содержимому, не промпту
            continue
        for pat in p.get("prompt_patterns", []):
            if pat.upper() in upper_all:
                log.info(f"Модель по prompt '{pat}': {mk}")
                return mk

    # Detect-паттерны
    for mk, p in SWITCH_PROFILES.items():
        for pat in p["detect_patterns"]:
            if pat.upper() in upper_all:
                log.info(f"Модель по паттерну '{pat}': {mk}")
                return mk

    return None


def parse_serial(text):
    """Извлечь серийный номер из вывода show system information."""
    m = re.search(r'Hardware Serial Number\s*:\s*(\S+)', text, re.IGNORECASE)
    return m.group(1) if m else ""


# ─── SSH Shell Session ────────────────────────────────────────────────────────

class ShellSession:
    def __init__(self, host, username, password,
                 enable_password=None, source_ip=None, timeout=20):
        self.host    = host
        self.timeout = timeout
        self.tr      = None
        self.ch      = None
        self.prompt  = ""

        tcp_ok, tcp_err = check_tcp(host, 22, timeout=min(timeout, 8))
        if not tcp_ok:
            raise ConnectionError(tcp_err)

        sock = _make_socket(host, 22, source_ip, timeout)
        self.tr = paramiko.Transport(sock)
        self.tr.set_keepalive(0)

        self.tr._preferred_kex = (
            'curve25519-sha256', 'curve25519-sha256@libssh.org',
            'ecdh-sha2-nistp256', 'ecdh-sha2-nistp384', 'ecdh-sha2-nistp521',
            'diffie-hellman-group14-sha256',
            'diffie-hellman-group14-sha1',
            'diffie-hellman-group-exchange-sha256',
            'diffie-hellman-group-exchange-sha1',
            'diffie-hellman-group1-sha1',
        )
        self.tr._preferred_ciphers = (
            'aes128-ctr','aes192-ctr','aes256-ctr',
            'aes128-cbc','aes192-cbc','aes256-cbc','3des-cbc',
        )
        self.tr._preferred_macs = (
            'hmac-sha2-256','hmac-sha2-512','hmac-sha1','hmac-md5',
        )
        self.tr._preferred_keys = (
            'ssh-rsa','ecdsa-sha2-nistp256','ecdsa-sha2-nistp384',
            'ecdsa-sha2-nistp521','ssh-ed25519',
            'rsa-sha2-256','rsa-sha2-512','ssh-dss',
        )

        self.tr.start_client(timeout=timeout)
        self.tr.auth_password(username, password)
        if not self.tr.is_authenticated():
            raise paramiko.AuthenticationException("Аутентификация не прошла")

        self.ch = self.tr.open_session()
        self.ch.settimeout(timeout)
        self.ch.get_pty(term='vt100', width=220, height=50)
        self.ch.invoke_shell()

        banner = self._read(timeout=10, stop_on_patterns=["#", ">", "yes/no", "password", "assword"])
        log.debug(f"Banner [{host}]: {repr(strip_ansi(banner)[-150:])}")

        if "yes/no" in banner.lower() or "authenticity" in banner.lower():
            log.info(f"Fingerprint [{host}] → yes")
            self.ch.send("yes\n")
            banner += self._read(timeout=8, stop_on_patterns=["#", ">", "password", "assword"])

        if "password" in banner.lower() or "assword" in banner.lower():
            self.ch.send(password + "\n")
            banner += self._read(timeout=8, stop_on_patterns=["#", ">"])

        self.prompt = self._extract_prompt(banner)
        log.info(f"Shell [{host}], промпт: '{self.prompt}'")

        if enable_password is not None:
            self._do_enable(enable_password)

        for cmd in ["terminal length 0", "terminal datadump"]:
            self.ch.send(cmd + "\n")
            time.sleep(0.3)
            self._drain()

    def _extract_prompt(self, text):
        clean = strip_ansi(text)
        for line in reversed(clean.splitlines()):
            s = line.strip()
            if s and (s.endswith('#') or s.endswith('>')):
                return re.sub(r'[#>].*$', '', s).strip()
        return ""

    def _do_enable(self, pw):
        self.ch.send("enable\n"); time.sleep(0.5)
        buf = self._read(timeout=5, stop_on_patterns=["password","assword","#",">"])
        if "password" in buf.lower() or "assword" in buf.lower():
            self.ch.send(pw + "\n"); time.sleep(0.5)
            self._read(timeout=5, stop_on_patterns=["#",">"])
            log.info(f"Enable OK [{self.host}]")

    def _read(self, timeout=15, stop_on_prompt=True, stop_on_patterns=None):
        patterns = stop_on_patterns or []
        buf = ""; deadline = time.time() + timeout
        while time.time() < deadline:
            if self.ch.recv_ready():
                buf += self.ch.recv(4096).decode("utf-8", errors="replace")
                clean = strip_ansi(buf).rstrip()
                if stop_on_prompt and (clean.endswith('#') or clean.endswith('>')):
                    break
                if patterns:
                    cl = clean.lower()
                    if any(p.lower() in cl for p in patterns):
                        break
            else:
                time.sleep(0.05)
        return buf

    def _drain(self, t=1.5):
        dead = time.time() + t
        while time.time() < dead:
            if self.ch.recv_ready(): self.ch.recv(4096)
            else: time.sleep(0.05); break

    def run(self, command, extra_wait=0):
        log.debug(f"run [{self.host}]: {command}")
        self.ch.send(command + "\n")
        # Пауза перед чтением — SF300/Linksys медленно готовят ответ
        time.sleep(0.5 + extra_wait)
        raw = self._read(timeout=self.timeout)
        output = strip_ansi(raw)
        lines = []
        for line in output.splitlines():
            s = line.strip()
            if not s: continue
            if s.endswith('#') or s.endswith('>'): continue
            if command.strip() in s: continue
            lines.append(line)
        result = "\n".join(lines).strip() or "(нет вывода)"
        log.debug(f"[{command[:40]}]: {result[:200]}")
        return result

    def close(self):
        try: self.ch.close()
        except Exception: pass
        try: self.tr.close()
        except Exception: pass


# ─── Single-command SSH wrapper ───────────────────────────────────────────────

def ssh_run(host, username, password, command,
            enable_password=None, source_ip=None, timeout=20, extra_wait=0):
    log.info(f"SSH [{host}] cmd='{command}'")
    try:
        sess = ShellSession(host, username, password,
                            enable_password=enable_password,
                            source_ip=source_ip, timeout=timeout)
        result = sess.run(command, extra_wait=extra_wait)
        ph = sess.prompt; sess.close()
        return {"success": True, "output": result, "prompt_hint": ph}
    except ConnectionError as e:
        return {"success": False, "error": str(e), "stage": "tcp"}
    except paramiko.AuthenticationException as e:
        return {"success": False, "error": f"Ошибка аутентификации: {e}", "stage": "auth"}
    except paramiko.SSHException as e:
        err = str(e)
        hint = ""
        if any(w in err.lower() for w in ("kex","cipher","no matching","key exchange","host key")):
            hint = (f"\n\nДобавь в ~/.ssh/config:\n"
                    f"  Host {host}\n    KexAlgorithms +diffie-hellman-group1-sha1\n"
                    f"    HostKeyAlgorithms +ssh-dss,ssh-rsa\n    Ciphers +aes128-cbc,3des-cbc")
        return {"success": False, "error": f"SSH ошибка: {err}{hint}", "stage": "ssh"}
    except socket.timeout:
        return {"success": False, "error": f"Таймаут {timeout}с", "stage": "timeout"}
    except Exception as e:
        log.error(traceback.format_exc())
        return {"success": False, "error": f"{type(e).__name__}: {e}", "stage": "unknown"}


# ─── Telnet (pure socket) ─────────────────────────────────────────────────────
#
# Ключевые особенности:
# - Linksys ожидает \r\n (Telnet-стандарт), а не просто \n
# - Linksys: User Name → Password → промпт (без повторного логина)
#   Если после пароля снова User Name → неверный пароль
# - Persistent-сессия: подключение держится пока не закроем
# - terminal length 0 отправляется после входа

class _Telnet:
    IAC=255; DONT=254; DO=253; WONT=252; WILL=251; SB=250; SE=240

    def __init__(self, host, port, timeout, source_ip=None):
        self.sock = _make_socket(host, port, source_ip, timeout)
        self._base_timeout = timeout
        self._buf = b""

    def _negotiate(self, data):
        """Обрабатывает IAC-команды Telnet, автоматически отклоняя опции."""
        out = b""; i = 0
        while i < len(data):
            b = data[i]
            if b == self.IAC:
                if i+1 >= len(data):
                    break
                cmd = data[i+1]
                if cmd in (self.DO, self.WILL, self.DONT, self.WONT):
                    if i+2 < len(data):
                        opt = data[i+2]
                        # Отказываемся от всех опций кроме эха (opt=1) — принимаем
                        if cmd == self.DO:
                            reply = self.WILL if opt == 1 else self.WONT
                        elif cmd == self.WILL:
                            reply = self.DO if opt == 1 else self.DONT
                        else:
                            reply = self.WONT if cmd == self.DONT else self.DONT
                        try:
                            self.sock.sendall(bytes([self.IAC, reply, opt]))
                        except Exception:
                            pass
                        i += 3
                    else:
                        i += 2
                elif cmd == self.SB:
                    # Пропускаем subnegotiation до SE
                    end = data.find(bytes([self.IAC, self.SE]), i+2)
                    i = end + 2 if end != -1 else len(data)
                elif cmd == self.IAC:
                    out += bytes([self.IAC]); i += 2
                else:
                    i += 2
            else:
                out += bytes([b]); i += 1
        return out

    def read_until_any(self, patterns, timeout=6):
        deadline = time.time() + timeout
        while time.time() < deadline:
            try:
                self.sock.settimeout(min(0.3, deadline - time.time()))
                chunk = self.sock.recv(4096)
                if chunk:
                    self._buf += self._negotiate(chunk)
                    dec = self._buf.decode("utf-8", errors="replace").lower()
                    for p in patterns:
                        if p.lower() in dec:
                            r = self._buf.decode("utf-8", errors="replace")
                            self._buf = b""
                            return r
                elif not chunk:  # соединение закрыто
                    break
            except socket.timeout:
                pass
            except OSError:
                break
        r = self._buf.decode("utf-8", errors="replace")
        self._buf = b""
        return r

    def write(self, data: bytes):
        """Отправляет данные. Telnet-стандарт — \r\n."""
        self.sock.sendall(data)

    def writeln(self, text: str):
        """Отправляет строку с Telnet-переводом строки \r\n."""
        self.sock.sendall(text.encode("utf-8", errors="replace") + b"\r\n")

    def close(self):
        try: self.sock.close()
        except Exception: pass


class TelnetSession:
    """
    Persistent Telnet-сессия — открывается один раз, держится для всех команд.
    Особая обработка Linksys (User Name: → Password: → промпт).
    """

    # Все варианты приглашений
    _LOGIN_P  = ["user name:","login:","username:","user:"]
    _PASSWD_P = ["password:","pass:","passwd:","secret:","assword:"]
    _PROMPT_P = ["#",">","$"]

    def __init__(self, host, username, password,
                 enable_password=None, source_ip=None, timeout=20):
        self.host    = host
        self.timeout = timeout
        self.prompt  = ""

        tcp_ok, tcp_err = check_tcp(host, 23, timeout=min(timeout,8))
        if not tcp_ok:
            raise ConnectionError(tcp_err)

        self.tn = _Telnet(host, 23, timeout=timeout, source_ip=source_ip)
        self._login(username, password, enable_password)

    def _has(self, text, pats):
        t = text.lower()
        return any(p in t for p in pats)

    def _login(self, username, password, enable_pw):
        all_pats = ["yes/no"] + self._LOGIN_P + self._PASSWD_P + self._PROMPT_P
        banner = self.tn.read_until_any(all_pats, timeout=12)
        log.debug(f"TelnetSession banner [{self.host}]: {repr(banner[-120:])}")

        # Fingerprint
        if "yes/no" in banner.lower():
            self.tn.writeln("yes"); time.sleep(0.4)
            banner = self.tn.read_until_any(
                self._LOGIN_P + self._PASSWD_P + self._PROMPT_P, timeout=8)

        # Ввод логина
        if self._has(banner, self._LOGIN_P):
            log.debug(f"TelnetSession: логин [{self.host}]")
            self.tn.writeln(username); time.sleep(0.8)
            banner = self.tn.read_until_any(self._PASSWD_P + self._PROMPT_P, timeout=8)
            log.debug(f"TelnetSession after-login [{self.host}]: {repr(banner[-80:])}")

        # Ввод пароля
        if self._has(banner, self._PASSWD_P):
            log.debug(f"TelnetSession: пароль [{self.host}]")
            self.tn.writeln(password); time.sleep(1.2)
            banner = self.tn.read_until_any(self._PROMPT_P + self._LOGIN_P, timeout=10)
            log.debug(f"TelnetSession after-pass [{self.host}]: {repr(banner[-80:])}")

            # Если после пароля снова логин — неверный пароль
            if self._has(banner, self._LOGIN_P):
                raise paramiko.AuthenticationException(
                    "Telnet: неверный логин или пароль (свитч снова запросил User Name:)")

        # Извлечь промпт
        for line in reversed(strip_ansi(banner).splitlines()):
            s = line.strip()
            if s and (s.endswith('#') or s.endswith('>')):
                self.prompt = re.sub(r'[#>].*$','',s).strip(); break

        log.info(f"TelnetSession: вошли [{self.host}], промпт='{self.prompt}'")

        # Enable
        if enable_pw is not None:
            self.tn.writeln("enable"); time.sleep(0.5)
            en = self.tn.read_until_any(self._PASSWD_P + self._PROMPT_P, timeout=5)
            if self._has(en, self._PASSWD_P):
                self.tn.writeln(enable_pw); time.sleep(0.8)
                self.tn.read_until_any(self._PROMPT_P, timeout=5)
            log.debug(f"TelnetSession: enable [{self.host}]")

        # Отключить пагинацию
        self.tn.writeln("terminal length 0"); time.sleep(0.4)
        self.tn.read_until_any(self._PROMPT_P, timeout=3)

    def run(self, command):
        log.debug(f"TelnetSession.run [{self.host}]: {command}")
        self.tn.writeln(command)
        time.sleep(0.5)
        raw = self.tn.read_until_any(self._PROMPT_P, timeout=self.timeout)
        output = strip_ansi(raw)
        lines = [l for l in output.splitlines()
                 if l.strip()
                 and command.strip() not in l
                 and not l.strip().endswith('#')
                 and not l.strip().endswith('>')]
        result = "\n".join(lines).strip()
        log.info(f"TelnetSession result [{self.host}]: {len(result)} байт")
        return result or "(нет вывода)"

    def close(self):
        try:
            self.tn.writeln("exit")
            time.sleep(0.2)
        except Exception:
            pass
        self.tn.close()


def telnet_run(host, username, password, command,
               enable_password=None, source_ip=None, timeout=15):
    """Telnet: открывает сессию, выполняет одну команду, закрывает."""
    log.info(f"Telnet [{host}] cmd='{command}'")
    sess = None
    try:
        sess = TelnetSession(host, username, password,
                             enable_password=enable_password,
                             source_ip=source_ip, timeout=timeout)
        result = sess.run(command)
        ph = sess.prompt
        return {"success": True, "output": result, "prompt_hint": ph}
    except ConnectionError as e:
        return {"success": False, "error": str(e), "stage": "tcp"}
    except paramiko.AuthenticationException as e:
        return {"success": False, "error": str(e), "stage": "auth"}
    except Exception as e:
        log.error(traceback.format_exc())
        return {"success": False, "error": f"Telnet: {type(e).__name__}: {e}", "stage": "telnet"}
    finally:
        if sess:
            try: sess.close()
            except Exception: pass


# ─── Dispatcher ───────────────────────────────────────────────────────────────

def run_command(host, username, password, command,
                protocol="ssh", enable_password=None, source_ip=None,
                timeout=20, extra_wait=0):
    if protocol == "telnet":
        return telnet_run(host, username, password, command,
                          enable_password=enable_password,
                          source_ip=source_ip, timeout=timeout)
    return ssh_run(host, username, password, command,
                   enable_password=enable_password,
                   source_ip=source_ip, timeout=timeout, extra_wait=extra_wait)


# ─── Model detection: ОДИН SSH-сеанс ─────────────────────────────────────────

def detect_model(host, username, password, protocol="ssh",
                 enable_password=None, source_ip=None):
    log.info(f"Определение модели [{host}] proto={protocol}")

    if protocol == "telnet":
        prompt_hint = ""; all_out = ""; serial = ""
        for cmd in DETECT_COMMANDS:
            r = telnet_run(host, username, password, cmd,
                           enable_password=enable_password,
                           source_ip=source_ip, timeout=15)
            if r.get("prompt_hint"): prompt_hint = r["prompt_hint"]
            raw_out = r.get("output","")
            if raw_out:
                all_out += "\n" + raw_out
                if not serial: serial = parse_serial(raw_out)
                log.debug(f"[{cmd}] telnet: {raw_out[:200]}")
                # Проверяем совпадение в любом случае (даже если команда не выполнилась)
                m = match_model(raw_out, prompt_hint, serial)
                if m: return m, None
            if r.get("stage") in ("tcp","auth"):
                return None, r["error"]
        if prompt_hint or all_out:
            m = match_model(all_out, prompt_hint, serial)
            if m: return m, None
        return "unknown", f"Промпт: {prompt_hint}\n{all_out[:400]}"

    # SSH: один сеанс
    tcp_ok, tcp_err = check_tcp(host, 22, timeout=8)
    if not tcp_ok:
        return None, tcp_err

    try:
        sess = ShellSession(host, username, password,
                            enable_password=enable_password,
                            source_ip=source_ip, timeout=20)
        prompt_hint = sess.prompt
        all_out = ""; serial = ""

        # Проверить промпт сразу (для mes2424b 28port)
        m = match_model("", prompt_hint, serial)
        if m:
            sess.close(); return m, None

        for cmd in DETECT_COMMANDS:
            out = sess.run(cmd)
            log.debug(f"[{cmd}]: {out[:250]}")
            all_out += "\n" + out
            if not serial: serial = parse_serial(out)
            m = match_model(out, prompt_hint, serial)
            if m: break

        sess.close()
        if m: return m, None

        m = match_model(all_out, prompt_hint, serial)
        if m: return m, None

        log.warning(f"Модель не определена [{host}], промпт='{prompt_hint}', serial='{serial}'")
        return "unknown", f"Промпт: {prompt_hint}\nСерийник: {serial}\n{all_out[:600]}"

    except ConnectionError as e:
        return None, str(e)
    except paramiko.AuthenticationException as e:
        return None, f"Ошибка аутентификации: {e}"
    except paramiko.SSHException as e:
        err = str(e)
        hint = ""
        if any(w in err.lower() for w in ("kex","no acceptable","host key","dss")):
            hint = (f"\n\nДобавь в ~/.ssh/config:\n  Host {host}\n"
                    f"    KexAlgorithms +diffie-hellman-group1-sha1\n"
                    f"    HostKeyAlgorithms +ssh-dss,ssh-rsa\n    Ciphers +aes128-cbc,3des-cbc")
        return None, f"SSH ошибка: {err}{hint}"
    except Exception as e:
        log.error(traceback.format_exc())
        return None, f"{type(e).__name__}: {e}"


# ─── Flask routes ─────────────────────────────────────────────────────────────

@app.route("/")
def index():
    return render_template("index.html")


@app.route("/api/local_ip")
def local_ip():
    return jsonify({"ip": get_local_ip()})


@app.route("/api/log")
def get_log():
    n = int(request.args.get("lines", 150))
    try:
        with open(LOG_FILE, "r", encoding="utf-8") as f:
            lines = f.readlines()
        return jsonify({"success": True, "log": "".join(lines[-n:])})
    except FileNotFoundError:
        return jsonify({"success": True, "log": "(пусто)"})


@app.route("/api/connect", methods=["POST"])
def connect():
    d = request.json
    host        = d.get("host","").strip()
    username    = d.get("username","").strip()
    pw_file     = d.get("password_file","passwords.txt").strip()
    protocol    = d.get("protocol","ssh")
    source_ip   = d.get("source_ip","").strip() or None
    use_enable  = d.get("use_enable", False)
    enable_same = d.get("enable_same", True)
    en_pw_file  = d.get("enable_pw_file","").strip()

    log.info(f"=== CONNECT host={host} user={username} proto={protocol} src={source_ip} enable={use_enable}")

    if not host or not username:
        return jsonify({"success": False, "error": "Укажите хост и логин"})

    password = load_password(pw_file)
    if password is None:
        return jsonify({"success": False, "error": f"Файл паролей не найден: {pw_file}"})

    enable_pw = None
    if use_enable:
        if enable_same:
            enable_pw = password
        elif en_pw_file:
            enable_pw = load_password(en_pw_file)
            if enable_pw is None:
                return jsonify({"success": False, "error": f"Файл enable-пароля не найден: {en_pw_file}"})
        else:
            enable_pw = password

    model_key, error = detect_model(host, username, password,
                                    protocol=protocol, enable_password=enable_pw,
                                    source_ip=source_ip)
    if model_key is None:
        return jsonify({"success": False, "error": error})

    profile = SWITCH_PROFILES.get(model_key, {})
    model_name = profile.get("display_name", "Неизвестная модель")
    port_types = profile.get("port_types", ["fa"])
    default_port_type = profile.get("default_port_type", port_types[0] if port_types else "fa")

    log.info(f"Подключено: {host} → {model_key} ({model_name})")

    return jsonify({
        "success":          True,
        "model_key":        model_key,
        "model_name":       model_name,
        "host":             host,
        "username":         username,
        "protocol":         protocol,
        "source_ip":        source_ip,
        "enable_password":  enable_pw,
        "port_types":       port_types,
        "default_port_type": default_port_type,
        "raw_version":      error if model_key == "unknown" else None,
    })


@app.route("/api/run", methods=["POST"])
def run_action():
    d           = request.json
    host        = d.get("host")
    username    = d.get("username")
    pw_file     = d.get("password_file","passwords.txt")
    model_key   = d.get("model_key","unknown")
    action      = d.get("action")
    port_num    = d.get("port_num","1")       # номер порта (1, 2, 3...)
    port_type   = d.get("port_type","fa")     # тип порта (fa, gi, fa1/0, gi0, e, g)
    protocol    = d.get("protocol","ssh")
    source_ip   = d.get("source_ip") or None
    enable_pw   = d.get("enable_password") or None

    password = load_password(pw_file)
    if password is None:
        return jsonify({"success": False, "error": "Файл паролей не найден"})

    profile = SWITCH_PROFILES.get(model_key)
    if not profile:
        return jsonify({"success": False, "error": f"Нет профиля: {model_key}"})

    tpl = profile["commands"].get(action)
    if not tpl:
        return jsonify({"success": False, "error": f"Действие '{action}' не поддерживается"})

    # Формируем полное обозначение порта: тип + номер
    # Примеры: fa1, gi3, fa1/0/5, gi0/3, e5, g1
    port = f"{port_type}{port_num}"
    command = tpl.format(port=port)
    log.info(f"RUN [{host}] action={action} port={port} cmd='{command}'")

    # cable_test: результат выводится сразу, отдельный cable_result не нужен
    result = run_command(host, username, password, command,
                         protocol=protocol, enable_password=enable_pw,
                         source_ip=source_ip)
    result["command"] = command
    return jsonify(result)


@app.route("/api/custom", methods=["POST"])
def custom():
    d         = request.json
    host      = d.get("host")
    username  = d.get("username")
    pw_file   = d.get("password_file","passwords.txt")
    command   = d.get("command","").strip()
    model_key = d.get("model_key","unknown")
    protocol  = d.get("protocol","ssh")
    source_ip = d.get("source_ip") or None
    enable_pw = d.get("enable_password") or None

    if not command:
        return jsonify({"success": False, "error": "Введите команду"})

    password = load_password(pw_file)
    if password is None:
        return jsonify({"success": False, "error": "Файл паролей не найден"})

    result = run_command(host, username, password, command,
                         protocol=protocol, enable_password=enable_pw,
                         source_ip=source_ip)
    result["command"] = command
    return jsonify(result)


if __name__ == "__main__":
    app.run(debug=True, host="0.0.0.0", port=5000, threaded=True)
